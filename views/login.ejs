<%- include('includes/_header') %>

<div class="auth-layout">
    <div class="auth-card">
        <div class="auth-card-header">
            <p class="auth-eyebrow">Acceso</p>
            <h2 class="auth-title">Iniciar sesión</h2>
            <p class="auth-copy">Ingresa con tu cuenta para acceder a las secciones autorizadas del sistema.</p>
        </div>

        <%- include('includes/_error') %>

        <form action="/users/login" method="POST" class="auth-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" >
            <div class="field">
                <label for="username" class="label">Nombre de usuario</label>
                <div class="control">
                    <input id="username" name="username" class="input" type="text" placeholder="e.g Vi" required>
                </div>
            </div>

            <div class="field">
                <label for="password" class="label">Password</label>
                <div class="control">
                    <input id="password" name="password" class="input" type="password" required>
                </div>
            </div>

            <input class="button is-primary auth-submit" type="submit" value="Entrar">
        </form>
    </div>
</div>
<%- include('includes/_footer') %>
