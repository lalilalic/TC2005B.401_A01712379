<%- include('includes/_header') %>

        <div class="content-panel">
            <div class="action-row">
                <div>
                    <h2 class="section-title">Catalogo de personajes</h2>
                    <p class="section-copy">Consulta y administra los registros disponibles dentro de la plataforma.</p>
                </div>
                <a class="button is-primary" href="/personajes/new">Nuevo personaje</a>
            </div>

            <% if(personajes.length == 0) { %>
                <div class="empty-panel">
                    No hay personajes registrados.
                </div>
            <% } else { %>
                <div class="catalog-grid">
                <% for (let personaje of personajes) { %>
                    <article class="champion-card">
                        <a class="champion-link" href="/personajes/<%= personaje.id %>"><%= personaje.nombre %></a>
                        <figure class="champion-image">
                            <img src="<%= personaje.imagen %>" alt="<%= personaje.nombre %>" />
                        </figure>
                    </article>
                <% } %>
                </div>
            <% } %>
        </div>

<%- include('includes/_footer') %>
