<form action="/personajes/<%= editando ? 'edit' : 'new' %>" method="POST">
    <% if (editando) { %>
        <input type="hidden" name="personaje_id" value="<%= personaje.id %>">
    <% } %>
    <div class="field">
        <label for="nombre" class="label">Nombre</label>
        <div class="control">
            <input id="nombre" name="nombre" class="input" type="text" placeholder="e.g Mario" value="<%= personaje.nombre %>">
        </div>
    </div>

    <div class="field">
        <label for="descripcion" class="label">Descripción</label>
        <div class="control">
            <input id="descripcion" name="descripcion" class="input" type="text" placeholder="e.g. Heroe del Reino Champinon que rescata a Peach..." value="<%= personaje.descripcion %>">
        </div>
    </div>

    <div class="field">
        <div class="select">
            <select name="tipo" class="select">
                <% for(let tipo of tipos) { %>
                    <option value="<%= tipo.id %>" <%= Number(personaje.tipo_id) === Number(tipo.id) ? 'selected' : '' %>><%= tipo.tipo %></option>
                <% } %>
            </select>
        </div>
    </div>

    <div class="field">
        <label for="imagen" class="label">Imagen</label>
        <div class="control">
            <input id="imagen" name="imagen" class="input" type="text" placeholder="e.g. https://example.com/mario.jpg" value="<%= personaje.imagen %>">
        </div>
    </div>

    <input class="button is-primary" type="submit" value="<%= editando ? 'Guardar cambios' : 'Guardar personaje' %>">
</form>
