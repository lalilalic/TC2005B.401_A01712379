<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Lab19</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/app.css">
  </head>
  <body class="site-body">
    <nav class="navbar site-navbar" role="navigation" aria-label="main navigation">
      <div class="navbar-brand">
        <a class="navbar-item site-brand" href="/">
          <span class="site-brand-mark">L19</span>
          <span class="site-brand-text">Lab19</span>
        </a>

        <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbarBasicExample">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </a>
      </div>

      <div id="navbarBasicExample" class="navbar-menu">
        <div class="navbar-start">
          <% let puede_ver_personajes = false; %>
          <% let puede_administrar_rbac = false; %>
          <% for (let permiso of permisos || []) { %>
            <% if (permiso.nombre_privilegio == 'ver_personajes') { %>
              <% puede_ver_personajes = true; %>
            <% } %>
            <% if (permiso.nombre_privilegio == 'administrar_rbac') { %>
              <% puede_administrar_rbac = true; %>
            <% } %>
          <% } %>

          <a class="navbar-item" href="/users/info">
            RBAC
          </a>

          <% if (username != '' && puede_ver_personajes) { %> 
            <a class="navbar-item" href="/personajes">
              Viajes
            </a>
          <% } %>

          <% if (username != '' && puede_administrar_rbac) { %>
            <a class="navbar-item" href="/users/rbac">
              Administrar RBAC
            </a>
          <% } %>
        </div> 

        <div class="navbar-end">
          <div class="navbar-item">
            <div class="buttons">
              <% if (username == '') { %> 
                <a class="button is-primary" href="/users/signup">
                  <strong>Sign up</strong>
                </a>
                <a class="button is-light" href="/users/login">
                  Log in
                </a>
              <% } else { %> 
                <a class="button is-light" href="/users/logout">
                  Log out
                </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </nav>


    <section class="section">
      <div class="container">
        <div class="page-hero">
          <h1 class="title">
            <a href="/personajes">Lab19</a>
          </h1>
          <p class="subtitle">
              <% if (username != '') { %> 
                <span class="welcome-text">Hola,</span> <strong class="welcome-name"><%= username %></strong>
              <% } else { %>
                Plataforma web con control de acceso basado en roles.
              <% } %>
          </p>
        </div>
