<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>LAB 18</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/lab18.css">
  </head>
  <body>
    <div class="site-shell">
    <nav class="navbar site-navbar" role="navigation" aria-label="main navigation">
      <div class="navbar-brand">
        <a class="navbar-item" href="/">
          <div class="brand-lockup">
            <span class="brand-kicker">Business Console</span>
            <span class="brand-title">LAB 18</span>
          </div>
        </a>

        <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbarBasicExample">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </a>
      </div>

      <div id="navbarBasicExample" class="navbar-menu">
        <div class="navbar-start">
          <% if (username != '') { %> 
            <a class="navbar-item" href="/personajes">
              Catalogo
            </a>
          <% } %>
        </div> 

        <div class="navbar-end">
          <div class="navbar-item">
            <div class="buttons">
              <% if (username == '') { %> 
                <a class="button is-primary" href="/users/signup">
                  <strong>Crear cuenta</strong>
                </a>
                <a class="button is-light" href="/users/login">
                  Iniciar sesion
                </a>
              <% } else { %> 
                <a class="button is-light" href="/users/logout">
                  Cerrar sesion
                </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </nav>


    <section class="section">
      <div class="container">
        <div class="hero-panel">
          <div class="hero-kicker">Panel Administrativo</div>
          <h1 class="hero-title">
            <a href="/personajes">LAB 18</a>
          </h1>
          <p class="hero-copy">
            Sistema para agregar, consultar y organizar personajes dentro de un catalogo claro, ordenado y facil de administrar.
          </p>
          <p class="hero-meta">
              <% if (username != '') { %> 
                Sesion activa de <span class="hero-user"><%= username %></span>
              <% } else { %>
                Accede con una cuenta para administrar el catalogo.
              <% } %>
          </p>
        </div>
