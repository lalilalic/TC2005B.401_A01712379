<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Lab17</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <style>
      :root {
        --arena: #f4f7fb;
        --cielo: #d9efff;
        --mar: #6fb7de;
        --oceano: #1f5f8b;
        --profundo: #0f3554;
        --espuma: #f7fbff;
        --texto-claro: #f7fbff;
        --texto-oscuro: #12324a;
      }

      html {
        min-height: 100%;
        background: linear-gradient(180deg, var(--cielo) 0%, var(--mar) 28%, var(--oceano) 62%, var(--profundo) 100%);
      }

      body {
        min-height: 100vh;
        background: linear-gradient(180deg, var(--cielo) 0%, var(--mar) 28%, var(--oceano) 62%, var(--profundo) 100%);
        background-attachment: fixed;
        background-repeat: no-repeat;
        background-size: cover;
        color: var(--texto-claro);
      }

      .section {
        background: transparent;
      }

      .navbar.lab17-navbar {
        background: rgba(244, 247, 251, 0.95);
        box-shadow: 0 12px 30px rgba(15, 53, 84, 0.14);
      }

      .lab17-navbar .navbar-item,
      .lab17-navbar .navbar-link,
      .lab17-navbar .navbar-brand .navbar-item {
        color: var(--texto-oscuro);
      }

      .lab17-brand {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 0.04em;
      }

      .lab17-tagline {
        margin-left: 0.75rem;
        font-size: 0.95rem;
        color: var(--texto-oscuro);
      }

      .title,
      .title a,
      .subtitle,
      .subtitle strong,
      .label,
      .help,
      .message-body,
      .message-header,
      .navbar-menu a,
      .content,
      a {
        color: var(--texto-claro);
      }

      .title a:hover,
      a:hover {
        color: var(--espuma);
      }

      .input,
      .select select {
        background: rgba(247, 251, 255, 0.94);
        color: var(--texto-oscuro);
        border-color: rgba(15, 53, 84, 0.2);
      }

      .button.is-primary {
        background: #4aa3d6;
        border-color: #4aa3d6;
        color: #ffffff;
      }

      .button.is-primary:hover {
        background: #3a92c5;
        border-color: #3a92c5;
        color: #ffffff;
      }

      .button.is-light {
        background: var(--arena);
        color: var(--texto-oscuro);
      }

      .box,
      .message.is-danger .message-body {
        color: var(--texto-oscuro);
      }
    </style>
  </head>
  <body>
    <nav class="navbar lab17-navbar" role="navigation" aria-label="main navigation">
      <div class="navbar-brand">
        <a class="navbar-item" href="/">
          <span class="lab17-brand">Bulma</span>
          <span class="lab17-tagline">Lab17</span>
        </a>

        <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbarBasicExample">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </a>
      </div>

      <div id="navbarBasicExample" class="navbar-menu">
        <div class="navbar-start">
          <% if (username != '') { %> 
            <a class="navbar-item" href="/personajes">
              Reino Champinon
            </a>
          <% } %>
        </div> 

        <div class="navbar-end">
          <div class="navbar-item">
            <div class="buttons">
              <% if (username == '') { %> 
                <a class="button is-primary" href="/users/signup">
                  <strong>Sign up</strong>
                </a>
                <a class="button is-light" href="/users/login">
                  Log in
                </a>
              <% } else { %> 
                <a class="button is-light" href="/users/logout">
                  Log out
                </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </nav>


    <section class="section">
      <div class="container">
        <h1 class="title">
          <a href="/personajes">Mundo de Mario Bros</a>
        </h1>
          <p class="subtitle">
              <% if (username != '') { %> 
                Hola <strong><%= username %></strong>!
              <% } %>
          </p>
