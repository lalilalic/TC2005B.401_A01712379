<%- include('includes/_header') %>
<%- include('includes/_error') %>

<div class="columns">
    <div class="column">
        <h2 class="title is-4">Usuarios y roles</h2>
        <table class="table is-striped is-fullwidth">
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Nombre</th>
                    <th>Rol</th>
                </tr>
            </thead>
            <tbody>
                <% for (let registro of usuarios_roles) { %>
                    <tr>
                        <td><%= registro.username %></td>
                        <td><%= registro.nombre %></td>
                        <td><%= registro.nombre_rol || 'Sin rol' %></td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<div class="columns">
    <div class="column">
        <h2 class="title is-4">Asignar rol a usuario</h2>
        <form action="/users/rbac/asignar-rol" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="field">
                <label for="username" class="label">Usuario</label>
                <div class="control">
                    <input id="username" name="username" class="input" type="text" required>
                </div>
            </div>
            <div class="field">
                <label for="id_rol" class="label">Rol</label>
                <div class="control">
                    <div class="select">
                        <select id="id_rol" name="id_rol">
                            <% for (let rol of roles) { %>
                                <option value="<%= rol.id %>"><%= rol.nombre_rol %></option>
                            <% } %>
                        </select>
                    </div>
                </div>
            </div>
            <input class="button is-primary" type="submit" value="Asignar rol">
        </form>
    </div>

    <div class="column">
        <h2 class="title is-4">Asignar privilegio a rol</h2>
        <form action="/users/rbac/asignar-privilegio" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="field">
                <label for="id_rol_privilegio" class="label">Rol</label>
                <div class="control">
                    <div class="select">
                        <select id="id_rol_privilegio" name="id_rol">
                            <% for (let rol of roles) { %>
                                <option value="<%= rol.id %>"><%= rol.nombre_rol %></option>
                            <% } %>
                        </select>
                    </div>
                </div>
            </div>
            <div class="field">
                <label for="id_privilegio" class="label">Privilegio</label>
                <div class="control">
                    <div class="select">
                        <select id="id_privilegio" name="id_privilegio">
                            <% for (let privilegio of privilegios) { %>
                                <option value="<%= privilegio.id %>"><%= privilegio.nombre_privilegio %></option>
                            <% } %>
                        </select>
                    </div>
                </div>
            </div>
            <input class="button is-primary" type="submit" value="Asignar privilegio">
        </form>
    </div>
</div>

<div class="columns">
    <div class="column">
        <h2 class="title is-4">Roles y privilegios</h2>
        <table class="table is-striped is-fullwidth">
            <thead>
                <tr>
                    <th>Rol</th>
                    <th>Privilegio</th>
                </tr>
            </thead>
            <tbody>
                <% for (let registro of roles_privilegios) { %>
                    <tr>
                        <td><%= registro.nombre_rol %></td>
                        <td><%= registro.nombre_privilegio || 'Sin privilegio' %></td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('includes/_footer') %>
