<%- include('includes/_header') %>
<%- include('includes/_error') %>

<form action="/users/login" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" >
    <div class="field">
        <label for="username" class="label">Nombre de usuario</label>
        <div class="control">
            <input id="username" name="username" class="input" type="text" placeholder="e.g. viajera123" required>
        </div>
    </div>
    <div class="field">
        <label for="password" class="label">Contraseña</label>
        <div class="control">
            <input id="password" name="password" class="input" type="password" required>
        </div>
    </div>
    <input class="button is-primary" type="submit" value="Entrar">
</form>

<%- include('includes/_footer') %>