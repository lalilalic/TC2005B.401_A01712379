<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Mis viajes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap">
  </head>
  <body>
    <nav class="navbar is-light" role="navigation" aria-label="main navigation">
      <div class="navbar-brand">
        <a class="navbar-item" href="/">
          <strong style="font-family: 'Playfair Display', serif; font-size: 1.3rem; color: #3a2e26;">
            ✈️ Mis viajes
          </strong>
        </a>
      </div>

      <div class="navbar-menu">
        <div class="navbar-start">
          <% if (username != '') { %>
            <a class="navbar-item" href="/destinos">Destinos</a>
          <% } %>
        </div>

        <div class="navbar-end">
          <div class="navbar-item">
            <div class="buttons">
              <% if (username == '') { %>
                <a class="button is-primary" href="/users/signup"><strong>Registrarse</strong></a>
                <a class="button is-light" href="/users/login">Entrar</a>
              <% } else { %>
                <span class="navbar-item">Hola, <strong>&nbsp;<%= username %></strong></span>
                <a class="button is-light" href="/users/logout">Salir</a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <section class="section">
      <div class="container">